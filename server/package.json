{
  "name": "jbos-server",
  "version": "1.0.0",
  "private": true,
  "description": "JBOS Express + SQLite + Puppeteer backend",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
