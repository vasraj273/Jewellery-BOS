PORT=5000
NODE_ENV=development
# Neon PostgreSQL connection string. Append ?sslmode=require if the URL doesn't
# already include it. The driver also enforces ssl=require by default.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Optional pool size override (default: 5)
# PG_POOL_MAX=5
UPLOAD_DIR=../uploads
TEMPLATE_DIR=../templates
CLIENT_ORIGIN=http://localhost:5173
GST_RATE=0.03

# ── Gold Rate Provider ──────────────────────────────
# Provider: `mock` (default) | `goldapi` | `http`
GOLD_PROVIDER=mock

# When GOLD_PROVIDER=goldapi (https://www.goldapi.io):
# GOLD_API_KEY=goldapi-xxxx
# GOLD_API_SYMBOL=XAU         # XAU=gold, XAG=silver
# GOLD_API_CURRENCY=INR

# When GOLD_PROVIDER=http (generic):
# GOLD_API_URL=https://api.example.com/gold
# GOLD_API_KEY=
# GOLD_PROVIDER_NAME=metals-api

# Supported pricing locations (cities). Comma-separated.
# JBOS_LOCATIONS=Mumbai,Ahmedabad,Delhi,Bengaluru,Chennai,Kolkata,Hyderabad,Jaipur

# ── India Retail Markup Layer (optional) ────────────
# Adjusts international spot to retail by adding duty + GST + jeweller margin.
# Set GOLD_USE_MARKUP=false when switching to a true India-side provider.
GOLD_USE_MARKUP=false
GOLD_INDIA_MARKUP_PCT=18

# ── WhatsApp Cloud API (Meta Graph) ─────────────────
# Generate permanent token via Meta Business Manager > System Users.
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WABA_ID=
# WHATSAPP_GRAPH_VERSION=v20.0
# Approved template (Header: Document, Body: {{1}} name, {{2}} quote_id, {{3}} final_price).
# WHATSAPP_TEMPLATE_NAME=quotation_document
# WHATSAPP_TEMPLATE_LANG=en

# ── Scheduler ───────────────────────────────────────
GOLD_FETCH_ENABLED=true
GOLD_FETCH_CRON=0 9 * * *
TZ=Asia/Kolkata
